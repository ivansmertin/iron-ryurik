# Database Configuration
# Pooled connection string (port 6543) for Supabase / pgbouncer
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Direct connection string (port 5432) for running Migrations/Prisma introspect
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Supabase Auth & Storage (Client Side)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase Admin (Server Side)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# QR attendance tokens (server side, min 32 chars)
QR_SIGNING_SECRET="replace-with-a-random-32-byte-secret"

# Cron endpoints (server side, min 16 chars)
CRON_SECRET="replace-with-a-random-16-byte-secret"

# Web Push / PWA Notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:notifications@example.com"

# Email Notifications
# Options: 'gmail' or 'brevo'
EMAIL_PROVIDER="gmail"
EMAIL_FROM="Iron Rurik <notifications@example.com>"

# If using Gmail (Email Provider)
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="your-app-password"

# If using Brevo (Email Provider)
BREVO_API_KEY="your-brevo-api-key"

# Build Time Configuration
# Set to 'true' in Vercel 'Build and Development Settings' only if needed to skip validation
SKIP_ENV_VALIDATION="false"
