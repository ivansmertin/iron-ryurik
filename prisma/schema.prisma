generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ============ ПОЛЬЗОВАТЕЛИ ============

enum UserRole {
  client
  trainer
  admin
}

enum Sport {
  running
  trail
  triathlon
  skiing
  other
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  // id совпадает с Supabase auth.users.id
  email          String
  fullName       String
  phone          String?
  role           UserRole @default(client)
  sport          Sport?
  birthDate      DateTime?
  avatarUrl      String?
  notes          String?  // заметки админа/тренера о пользователе
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  trainerProfile    TrainerProfile?
  memberships       Membership[]
  bookings          Booking[]
  workoutLogs       WorkoutLog[]
  programs          Program[]         @relation("ClientPrograms")
  assignedPrograms  Program[]         @relation("TrainerPrograms")
  sessionsAsTrainer Session[]         @relation("TrainerSessions")
  measurements      Measurement[]
  deviceIntegrations DeviceIntegration[]
  subscriptions      DeviceSubscription[]

  @@index([role])
  @@index([email])
  @@index([role, deletedAt, createdAt(sort: Desc)])
}

model TrainerProfile {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @db.Uuid
  specialization String?  // "бег, триатлон"
  bio            String?
  experienceYears Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ АБОНЕМЕНТЫ ============

enum MembershipStatus {
  active
  expired
  cancelled
  frozen
}

model MembershipPlan {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   // "Абонемент 12 занятий"
  visits          Int      // количество занятий
  durationDays    Int      // срок действия в днях с момента активации
  price           Decimal  @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships Membership[]
}

// Partial unique index "Membership_userId_active_key" на (userId) WHERE status='active'
// создаётся миграцией 20260417120000_unique_active_membership.
// Prisma не поддерживает WHERE в @@unique — индекс живёт только в миграции.
model Membership {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @db.Uuid
  planId          String           @db.Uuid
  visitsRemaining Int
  visitsTotal     Int
  startsAt        DateTime
  endsAt          DateTime
  status          MembershipStatus @default(active)
  paidAt          DateTime?        // админ отмечает оплату вручную
  paidAmount      Decimal?         @db.Decimal(10, 2)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  plan     MembershipPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  bookings Booking[]

  @@index([userId, status])
  @@index([endsAt])
  @@index([userId, status, endsAt])
}

// ============ РАСПИСАНИЕ И ЗАПИСЬ ============

enum SessionType {
  group       // групповой слот, вместимость N
  personal    // персональная тренировка 1-на-1
}

enum SessionStatus {
  scheduled
  cancelled
  completed
}

enum SessionOrigin {
  manual
  auto_free
}

model Session {
  id             String        @id @default(uuid()) @db.Uuid
  type           SessionType
  origin         SessionOrigin @default(manual)
  autoSlotKey    String?       @unique
  title          String?       // "ОФП для бегунов"
  description    String?
  trainerId      String?       @db.Uuid  // для personal обязательно, для group опционально
  startsAt       DateTime
  durationMinutes Int
  capacity       Int           // 1 для personal, 6-8 для group
  cancellationDeadlineHours Int @default(2)
  status         SessionStatus @default(scheduled)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  // версия для оптимистичной блокировки при бронировании
  version        Int           @default(0)

  trainer  User?     @relation("TrainerSessions", fields: [trainerId], references: [id], onDelete: SetNull)
  bookings Booking[]
  workoutLogs WorkoutLog[]

  @@index([startsAt])
  @@index([origin, startsAt])
  @@index([trainerId, startsAt])
  @@index([status, startsAt])
}

enum BookingStatus {
  pending
  cancelled
  completed
  no_show
}

enum BookingConfirmationMethod {
  qr
  manual
  no_show
}

model Booking {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @db.Uuid
  sessionId     String        @db.Uuid
  membershipId  String?       @db.Uuid  // какой абонемент списали
  status             BookingStatus              @default(pending)
  bookedAt           DateTime                   @default(now())
  cancelledAt        DateTime?
  cancelReason       String?
  confirmedAt        DateTime?
  confirmedById      String?                    @db.Uuid
  confirmationMethod BookingConfirmationMethod?

  user       User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  session    Session     @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  membership Membership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  // один пользователь не может дважды записаться на одну сессию
  @@unique([userId, sessionId])
  @@index([sessionId, status])
  @@index([userId, status])
  @@index([membershipId, status])
}

// ============ ТРЕНИРОВКИ И ПРОГРАММЫ ============

enum ExerciseCategory {
  strength_legs
  strength_upper
  strength_core
  plyometrics
  running_drills    // СБУ
  cardio
  mobility
  other
}

enum EquipmentType {
  barbell
  dumbbell
  kettlebell
  machine
  bodyweight
  treadmill
  bike
  rower
  other
}

model Exercise {
  id            String           @id @default(uuid()) @db.Uuid
  name          String
  category      ExerciseCategory
  equipment     EquipmentType
  description   String?
  videoUrl      String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  templateItems WorkoutTemplateItem[]
  logItems      ExerciseLog[]

  @@index([category])
}

model WorkoutTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items    WorkoutTemplateItem[]
  programs Program[]
}

model WorkoutTemplateItem {
  id               String   @id @default(uuid()) @db.Uuid
  templateId       String   @db.Uuid
  exerciseId       String   @db.Uuid
  orderIndex       Int
  targetSets       Int?
  targetReps       String?  // "8-12" или "10"
  targetRestSec    Int?
  notes            String?

  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercise Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([templateId, orderIndex])
}

model Program {
  id          String    @id @default(uuid()) @db.Uuid
  clientId    String    @db.Uuid
  trainerId   String    @db.Uuid
  templateId  String?   @db.Uuid
  name        String
  startsAt    DateTime
  endsAt      DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client   User             @relation("ClientPrograms",  fields: [clientId],  references: [id], onDelete: Cascade)
  trainer  User             @relation("TrainerPrograms", fields: [trainerId], references: [id], onDelete: Restrict)
  template WorkoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([trainerId])
  @@index([trainerId, clientId])
  @@index([trainerId, startsAt(sort: Desc)])
}

model WorkoutLog {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  sessionId   String?   @db.Uuid
  performedAt DateTime
  durationMin Int?
  rpe         Int?      // 1-10, субъективная оценка нагрузки
  notes       String?
  diaryReminderSentAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session  Session?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  exercises ExerciseLog[]

  @@unique([userId, sessionId])
  @@index([userId, performedAt])
  @@index([diaryReminderSentAt, performedAt])
}

model ExerciseLog {
  id           String   @id @default(uuid()) @db.Uuid
  workoutLogId String   @db.Uuid
  exerciseId   String   @db.Uuid
  orderIndex   Int
  // подходы в JSONB: [{setNumber, weight, reps, isWarmup, restSec}, ...]
  sets         Json
  notes        String?

  workoutLog WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  exercise   Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([workoutLogId, orderIndex])
}

// ============ ИЗМЕРЕНИЯ И ИНТЕГРАЦИИ ============

model Measurement {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  measuredAt DateTime
  weightKg   Decimal? @db.Decimal(5, 2)
  restingHr  Int?
  maxHr      Int?
  vo2max     Decimal? @db.Decimal(4, 1)
  notes      String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, measuredAt])
}

enum DeviceProvider {
  garmin
  strava
  polar
  suunto
}

model DeviceIntegration {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @db.Uuid
  provider     DeviceProvider
  accessToken  String         // храним зашифрованным
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  connectedAt  DateTime       @default(now())
  lastSyncAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// ============ НАСТРОЙКИ ЗАЛА ============

model GymState {
  id        Int      @id @default(1)
  occupancy Int      @default(0)
  updatedAt DateTime @updatedAt
}

// ============ WEB PUSH ПОДПИСКИ ============

model GymSettings {
  id                      Int      @id @default(1)
  freeSlotCapacity        Int      @default(8)
  freeSlotDurationMinutes Int      @default(60)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model GymWorkingHour {
  id              String   @id @default(uuid()) @db.Uuid
  weekday         Int      @unique
  isOpen          Boolean  @default(false)
  opensAtMinutes  Int      @default(540)
  closesAtMinutes Int      @default(1260)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DeviceSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
